<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 — Page Not Found | SOET Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
  <style>
    :root { --blue:#003399; --gold:#FFB800; }
    body {
      background: linear-gradient(135deg,#0a1628 0%,#003399 60%,#0055cc 100%);
      min-height: 100vh; font-family: 'Segoe UI', sans-serif;
      display: flex; align-items: center; justify-content: center;
    }
    .card-404 {
      background: rgba(255,255,255,0.97);
      border-radius: 24px;
      padding: 50px 40px;
      text-align: center;
      box-shadow: 0 30px 80px rgba(0,0,0,0.4);
      max-width: 520px;
      width: 100%;
    }
    .big-404 {
      font-size: 7rem; font-weight: 900;
      background: linear-gradient(135deg, #003399, #0077ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1; margin-bottom: 8px;
    }
    .orbit {
      width: 100px; height: 100px;
      border: 3px dashed #e0e7ff;
      border-radius: 50%;
      margin: 0 auto 24px;
      position: relative;
      animation: rotate 8s linear infinite;
    }
    .orbit-dot {
      width: 18px; height: 18px;
      background: var(--gold);
      border-radius: 50%;
      position: absolute;
      top: -9px; left: 50%;
      transform: translateX(-50%);
    }
    .orbit-center {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      font-size: 2rem;
      animation: counter-rotate 8s linear infinite;
    }
    @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes counter-rotate { from { transform: translate(-50%,-50%) rotate(0deg); } to { transform: translate(-50%,-50%) rotate(-360deg); } }
    .url-box {
      background: #f8f9ff; border: 1px solid #e0e7ff;
      border-radius: 10px; padding: 10px 16px;
      font-family: monospace; font-size: 0.85rem;
      color: #c62828; word-break: break-all;
      margin: 16px 0;
    }
    .btn-home {
      background: linear-gradient(135deg, #003399, #0055cc);
      color: white; border: none; border-radius: 12px;
      padding: 13px 32px; font-weight: 700;
      text-decoration: none; display: inline-flex;
      align-items: center; gap: 8px;
      transition: all 0.3s;
    }
    .btn-home:hover {
      background: linear-gradient(135deg,#002277,#003399);
      color: white; transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,51,153,0.3);
    }
  </style>
</head>
<body>
  <div class="card-404">
    <div class="orbit">
      <div class="orbit-dot"></div>
      <div class="orbit-center">🎓</div>
    </div>
    <div class="big-404">404</div>
    <h3 class="fw-bold mb-2" style="color:#1a1a1a;">Page Not Found</h3>
    <p class="text-muted mb-3">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="url-box">
      <i class="bi bi-link-45deg me-1"></i><%= url %>
    </div>
    <div class="d-flex gap-3 justify-content-center mt-4 flex-wrap">
      <a href="/" class="btn-home">
        <i class="bi bi-house-fill"></i>Go to Home
      </a>
      <a href="javascript:history.back()"
         style="background:#f0f4ff;color:#003399;border:2px solid #e0e7ff;border-radius:12px;padding:13px 24px;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:all 0.3s;"
         onmouseover="this.style.background='#e0e7ff'"
         onmouseout="this.style.background='#f0f4ff'">
        <i class="bi bi-arrow-left"></i>Go Back
      </a>
    </div>
    <div class="mt-4 text-muted" style="font-size:0.75rem;">
      SOET Resource Portal · KR Mangalam University
    </div>
  </div>
</body>
</html>