<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload PYQ — SOET Portal</title>
  <link href="/css/main.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    :root { --blue:#003399; --accent:#FFB800; }
    body { background:#f0f4ff; font-family:'Segoe UI',sans-serif; }
    .upload-card {
      background:white; border-radius:20px; padding:32px;
      box-shadow:0 4px 20px rgba(0,0,0,0.08); max-width:700px; margin:0 auto;
    }
    .form-label { font-weight:600; font-size:0.85rem; color:#555; }
    .form-control, .form-select {
      border-radius:10px; border-color:#e0e7ff; padding:10px 14px; font-size:0.9rem;
    }
    .form-control:focus, .form-select:focus {
      border-color:#7b1fa2; box-shadow:0 0 0 3px rgba(123,31,162,0.12);
    }
    .btn-submit {
      background:linear-gradient(135deg,#7b1fa2,#9c27b0);
      color:white; border:none; border-radius:12px;
      padding:13px 30px; font-weight:700; font-size:1rem; transition:all 0.3s;
    }
    .btn-submit:hover {
      background:linear-gradient(135deg,#6a1b9a,#7b1fa2);
      color:white; transform:translateY(-1px);
      box-shadow:0 6px 20px rgba(123,31,162,0.3);
    }
    .drop-zone {
      border:2px dashed #ce93d8; border-radius:14px;
      padding:36px 20px; text-align:center;
      cursor:pointer; transition:all 0.2s; background:#fdf6ff;
    }
    .drop-zone:hover { border-color:#7b1fa2; background:#f3e5f5; }
    .drop-zone.has-file { border-color:#2e7d32; background:#f1f8e9; }
    .type-grid {
      display:grid; grid-template-columns:repeat(3,1fr); gap:10px;
    }
    .type-btn {
      border:2px solid #e0e7ff; border-radius:12px;
      padding:14px 10px; text-align:center; cursor:pointer;
      transition:all 0.2s; background:white;
    }
    .type-btn .label { font-weight:700; font-size:0.88rem; color:#555; }
    .type-btn .sublabel { font-size:0.72rem; color:#aaa; margin-top:2px; }
    .type-btn:hover { border-color:#7b1fa2; }
    .type-btn.selected { background:#7b1fa2; border-color:#7b1fa2; }
    .type-btn.selected .label, .type-btn.selected .sublabel { color:white; }
  </style>
</head>
<body data-authenticated="true">

<%- include('../partials/facultyNavbar') %>

<div class="container-fluid px-3 px-md-4 py-4">

  <div class="upload-card">
    <div class="d-flex align-items-center gap-3 mb-4">
      <div style="width:52px;height:52px;background:#f3e5f5;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:#7b1fa2;">
        <i class="bi bi-file-earmark-plus-fill"></i>
      </div>
      <div>
        <h4 class="fw-bold mb-0">Upload Previous Year Paper</h4>
        <div class="text-muted" style="font-size:0.83rem;">PDF files only · Max 20MB</div>
      </div>
    </div>

    <% if (success) { %>
    <div id="page-toast" data-message="<%= success %>" data-type="success" class="d-none"></div>
    <% } %>
    <% if (error) { %>
    <div id="page-toast" data-message="<%= error %>" data-type="error" class="d-none"></div>
    <% } %>

    <form action="/faculty/pyq/upload" method="POST" enctype="multipart/form-data" id="pyqForm" data-loading="Uploading PYQ... Please wait">

      <!-- Subject -->
      <div class="mb-4">
        <label class="form-label">Subject <span class="text-danger">*</span></label>
        <select name="subjectCode" class="form-select" required id="subjectSelect">
          <option value="">— Select Subject —</option>
          <% subjectOptions.forEach(s => { %>
            <option value="<%= s.subjectCode %>">
              [Sem <%= s.semester %>] <%= s.subjectCode %> — <%= s.name %>
            </option>
          <% }); %>
        </select>
      </div>

      <!-- Exam Type -->
      <div class="mb-4">
        <label class="form-label d-block">Exam Type <span class="text-danger">*</span></label>
        <div class="type-grid" style="grid-template-columns: repeat(2,1fr);">
          <div class="type-btn" onclick="selectType('MidTerm')">
            <div class="label">📝 Mid-Term</div>
            <div class="sublabel">Mid Semester Examination</div>
          </div>
          <div class="type-btn" onclick="selectType('EndTerm')">
            <div class="label">📋 End-Term</div>
            <div class="sublabel">End Semester Examination</div>
          </div>
        </div>
        <input type="hidden" name="examType" id="examTypeInput" required>
      </div>

      <!-- Year + Semester Type -->
      <div class="row g-3 mb-4">
        <div class="col-6">
          <label class="form-label">Year <span class="text-danger">*</span></label>
          <select name="year" class="form-select" required>
            <option value="">— Select Year —</option>
            <% years.forEach(y => { %>
              <option value="<%= y %>"><%= y %></option>
            <% }); %>
          </select>
        </div>
        <div class="col-6">
          <label class="form-label">Semester Type <span class="text-danger">*</span></label>
          <select name="semesterType" class="form-select" required>
            <option value="">— Select —</option>
            <option value="odd">Odd (Jul–Nov)</option>
            <option value="even">Even (Jan–Jun)</option>
          </select>
        </div>
      </div>

      <!-- File -->
      <div class="mb-4">
        <label class="form-label">PDF File <span class="text-danger">*</span></label>
        <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
          <i class="bi bi-file-earmark-pdf fs-1 mb-2 d-block" style="color:#ce93d8;" id="dropIcon"></i>
          <div class="fw-semibold" style="color:#666;" id="dropText">Click to browse or drag & drop PDF</div>
          <div class="text-muted mt-1" style="font-size:0.78rem;" id="dropSub">Maximum 20MB · PDF only</div>
        </div>
        <input type="file" name="file" id="fileInput" accept=".pdf" class="d-none" required
          onchange="if(FileValidator.validate(this,'fileValidationMsg')) handleFile(this)">
        <div id="fileValidationMsg" class="file-validation-msg"></div>
      </div>

      <div class="d-flex gap-3">
        <button type="submit" class="btn btn-submit flex-grow-1">
          <i class="bi bi-cloud-upload me-2"></i>Upload PYQ
        </button>
        <a href="/faculty/dashboard" class="btn btn-outline-secondary" style="border-radius:12px;padding:13px 20px;">
          Cancel
        </a>
      </div>

    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script>
  function selectType(type) {
    document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('selected'));
    document.querySelector(`[onclick="selectType('${type}')"]`).classList.add('selected');
    document.getElementById('examTypeInput').value = type;
  }

  function handleFile(input) {
    const file = input.files[0];
    if (file) {
      document.getElementById('dropZone').classList.add('has-file');
      document.getElementById('dropIcon').style.color = '#2e7d32';
      document.getElementById('dropIcon').className = 'bi bi-file-earmark-check fs-1 mb-2 d-block';
      document.getElementById('dropText').textContent = file.name;
      document.getElementById('dropSub').textContent = `${(file.size/1024/1024).toFixed(2)} MB · PDF`;
    }
  }

  const dropZone = document.getElementById('dropZone');
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    const file = e.dataTransfer.files[0];
    if (file && file.type === 'application/pdf') {
      const input = document.getElementById('fileInput');
      const dt = new DataTransfer();
      dt.items.add(file);
      input.files = dt.files;
      handleFile(input);
    } else {
      console.warn('Please drop a PDF file only.');
    }
  });

  const urlParams = new URLSearchParams(window.location.search);
  const subjectParam = urlParams.get('subject');
  if (subjectParam) document.getElementById('subjectSelect').value = subjectParam;

  document.getElementById('pyqForm').addEventListener('submit', function(e) {
    if (!document.getElementById('examTypeInput').value) {
      e.preventDefault();
      Toast.warning('Please select an exam type (Mid-Term or End-Term).');
    }
  });

  $(document).ready(function() {
    $('#subjectSelect').select2({
      placeholder: '— Search or select subject —',
      allowClear: true,
      width: '100%'
    });
  });
</script>
</body>
</html>