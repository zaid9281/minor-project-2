<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Change Password — SOET Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
  <style>
    :root { --blue:#003399; }
    body { background:#f0f4ff; font-family:'Segoe UI',sans-serif; }
    .pw-card {
      background:white; border-radius:20px; padding:36px;
      box-shadow:0 4px 20px rgba(0,0,0,0.08);
      max-width:520px; margin:40px auto;
    }
    .form-control { border-radius:10px; border-color:#e0e7ff; padding:10px 14px; }
    .form-control:focus { border-color:var(--blue); box-shadow:0 0 0 3px rgba(0,51,153,0.12); }
    .strength-bar { height:6px; border-radius:3px; background:#eee; overflow:hidden; margin-top:6px; }
    .strength-fill { height:100%; border-radius:3px; transition:all 0.3s; width:0; }
    .req-item { font-size:0.78rem; display:flex; align-items:center; gap:6px; }
    .req-item.met { color:#2e7d32; }
    .req-item.unmet { color:#aaa; }
  </style>
</head>
<body data-authenticated="true">

<%- include('../partials/facultyNavbar') %>

<div class="container px-3 py-4">
  <div class="pw-card">

    <% if (success) { %>
      <div id="page-toast" data-message="<%= success %>" data-type="success" class="d-none"></div>
    <% } %>
    <% if (error) { %>
      <div id="page-toast" data-message="<%= error %>" data-type="error" class="d-none"></div>
    <% } %>

    <div class="d-flex align-items-center gap-3 mb-4">
      <div style="width:52px;height:52px;background:#eef2ff;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;color:var(--blue);">
        <i class="bi bi-shield-lock-fill"></i>
      </div>
      <div>
        <h4 class="fw-bold mb-0">Change Password</h4>
        <div class="text-muted" style="font-size:0.82rem;">Update your account password securely</div>
      </div>
    </div>

    <form action="/faculty/change-password" method="POST" data-loading="Updating password...">

      <div class="mb-3">
        <label class="form-label fw-semibold small text-muted">Current Password</label>
        <div class="input-group">
          <input type="password" name="currentPassword" id="currentPw" class="form-control" required
            placeholder="Enter current password" style="border-radius:10px 0 0 10px !important;">
          <button type="button" class="btn btn-outline-secondary" style="border-radius:0 10px 10px 0;border-left:0;"
            onclick="togglePw('currentPw','eye1')">
            <i class="bi bi-eye" id="eye1"></i>
          </button>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold small text-muted">New Password</label>
        <div class="input-group">
          <input type="password" name="newPassword" id="newPw" class="form-control" required
            placeholder="Min 8 chars, uppercase, number, symbol"
            style="border-radius:10px 0 0 10px !important;"
            oninput="checkStrength(this.value)">
          <button type="button" class="btn btn-outline-secondary" style="border-radius:0 10px 10px 0;border-left:0;"
            onclick="togglePw('newPw','eye2')">
            <i class="bi bi-eye" id="eye2"></i>
          </button>
        </div>
        <!-- Strength bar -->
        <div class="strength-bar mt-2">
          <div class="strength-fill" id="strengthFill"></div>
        </div>
        <div class="mt-2 d-flex flex-column gap-1" id="requirements">
          <div class="req-item unmet" id="req-len"><i class="bi bi-circle"></i>At least 8 characters</div>
          <div class="req-item unmet" id="req-upper"><i class="bi bi-circle"></i>One uppercase letter</div>
          <div class="req-item unmet" id="req-num"><i class="bi bi-circle"></i>One number</div>
          <div class="req-item unmet" id="req-sym"><i class="bi bi-circle"></i>One special character (@$!%*?&)</div>
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold small text-muted">Confirm New Password</label>
        <div class="input-group">
          <input type="password" name="confirmPassword" id="confirmPw" class="form-control" required
            placeholder="Re-enter new password"
            style="border-radius:10px 0 0 10px !important;"
            oninput="checkMatch()">
          <button type="button" class="btn btn-outline-secondary" style="border-radius:0 10px 10px 0;border-left:0;"
            onclick="togglePw('confirmPw','eye3')">
            <i class="bi bi-eye" id="eye3"></i>
          </button>
        </div>
        <div id="matchMsg" style="font-size:0.78rem;margin-top:6px;"></div>
      </div>

      <div class="alert alert-warning d-flex gap-2 align-items-start" style="border-radius:12px;font-size:0.82rem;">
        <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
        <span>After changing your password, you will be <strong>logged out automatically</strong> and must sign in again with the new password.</span>
      </div>

      <div class="d-flex gap-3 mt-3">
        <button type="submit" class="btn flex-grow-1 fw-bold"
          style="background:linear-gradient(135deg,#003399,#0055cc);color:white;border:none;border-radius:12px;padding:13px;">
          <i class="bi bi-shield-check me-2"></i>Update Password
        </button>
        <a href="/faculty/dashboard" class="btn btn-outline-secondary" style="border-radius:12px;padding:13px 20px;">
          Cancel
        </a>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script>
  function togglePw(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    input.type = input.type === 'password' ? 'text' : 'password';
    icon.className = input.type === 'password' ? 'bi bi-eye' : 'bi bi-eye-slash';
  }

  function checkStrength(val) {
    const checks = {
      'req-len':   val.length >= 8,
      'req-upper': /[A-Z]/.test(val),
      'req-num':   /\d/.test(val),
      'req-sym':   /[@$!%*?&]/.test(val),
    };
    let passed = Object.values(checks).filter(Boolean).length;
    Object.entries(checks).forEach(([id, ok]) => {
      const el = document.getElementById(id);
      el.className = `req-item ${ok ? 'met' : 'unmet'}`;
      el.querySelector('i').className = `bi ${ok ? 'bi-check-circle-fill' : 'bi-circle'}`;
    });
    const colors = ['#e0e0e0','#f44336','#ff9800','#ffc107','#4caf50'];
    const fill = document.getElementById('strengthFill');
    fill.style.width = `${passed * 25}%`;
    fill.style.background = colors[passed];
  }

  function checkMatch() {
    const pw = document.getElementById('newPw').value;
    const confirm = document.getElementById('confirmPw').value;
    const msg = document.getElementById('matchMsg');
    if (!confirm) { msg.textContent = ''; return; }
    if (pw === confirm) {
      msg.innerHTML = '<span style="color:#2e7d32"><i class="bi bi-check-circle me-1"></i>Passwords match</span>';
    } else {
      msg.innerHTML = '<span style="color:#c62828"><i class="bi bi-x-circle me-1"></i>Passwords do not match</span>';
    }
  }
</script>
</body>
</html>