<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error — SOET Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(135deg,#0a1628 0%,#7b1fa2 60%,#9c27b0 100%);
      min-height: 100vh; font-family: 'Segoe UI', sans-serif;
      display: flex; align-items: center; justify-content: center;
    }
    .error-card {
      background: rgba(255,255,255,0.97);
      border-radius: 24px; padding: 48px 40px;
      text-align: center; max-width: 500px; width: 100%;
      box-shadow: 0 30px 80px rgba(0,0,0,0.4);
    }
    .error-icon {
      width: 90px; height: 90px;
      background: linear-gradient(135deg,#fce4ec,#f8bbd0);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 24px; font-size: 2.5rem;
    }
    .btn-home {
      background: linear-gradient(135deg,#7b1fa2,#9c27b0);
      color: white; border: none; border-radius: 12px;
      padding: 12px 28px; font-weight: 700;
      text-decoration: none; display: inline-flex;
      align-items: center; gap: 8px; transition: all 0.3s;
    }
    .btn-home:hover { color: white; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(123,31,162,0.3); }
  </style>
</head>
<body>
  <div class="error-card">
    <div class="error-icon">⚠️</div>
    <h3 class="fw-bold mb-2" style="color:#1a1a1a;">Something Went Wrong</h3>
    <p class="text-muted mb-4"><%= message || 'An unexpected error occurred. Please try again.' %></p>
    <div class="d-flex gap-3 justify-content-center flex-wrap">
      <a href="/" class="btn-home"><i class="bi bi-house-fill"></i>Go Home</a>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="<%= user.role === 'student' ? '/student/dashboard' : '/faculty/dashboard' %>"
           style="background:#f0f4ff;color:#7b1fa2;border:2px solid #e1bee7;border-radius:12px;padding:12px 24px;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
          <i class="bi bi-arrow-left"></i>Back to Dashboard
        </a>
      <% } %>
    </div>
    <div class="mt-4 text-muted" style="font-size:0.75rem;">
      SOET Resource Portal · KR Mangalam University
    </div>
  </div>
</body>
</html>