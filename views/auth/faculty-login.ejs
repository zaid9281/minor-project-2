<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Faculty Login — SOET Portal</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/main.css" rel="stylesheet">
  <style>
    :root { --krmu-blue: #003399; --krmu-gold: #FFB800; }
    body {
      background: linear-gradient(135deg, #0a1628 0%, #003399 60%, #0055cc 100%);
      min-height: 100vh;
      font-family: 'Segoe UI', sans-serif;
    }
    .login-card {
      background: rgba(255,255,255,0.97);
      border-radius: 20px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.4);
      overflow: hidden;
    }
    .card-header-bar {
      background: linear-gradient(90deg, var(--krmu-blue), #0055cc);
      padding: 26px 30px;
    }
    .form-control:focus {
      border-color: var(--krmu-blue);
      box-shadow: 0 0 0 3px rgba(0,51,153,0.15);
    }
    .btn-login {
      background: linear-gradient(135deg, var(--krmu-blue), #0055cc);
      color: white;
      border: none;
      border-radius: 10px;
      padding: 13px;
      font-weight: 600;
      font-size: 1rem;
      transition: all 0.3s;
    }
    .btn-login:hover {
      background: linear-gradient(135deg, #002277, #003399);
      color: white;
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(0,51,153,0.35);
    }
    .input-group-text {
      background: #f0f4ff;
      border-color: #dee2e6;
      color: var(--krmu-blue);
    }
    .form-control {
      border-radius: 0 8px 8px 0 !important;
    }
    .input-group .input-group-text {
      border-radius: 8px 0 0 8px;
    }
    .badge-soet {
      background: var(--krmu-gold);
      color: #1a1a1a;
      font-weight: 700;
      font-size: 0.72rem;
      padding: 4px 10px;
      border-radius: 20px;
    }
  </style>
</head>
<body class="d-flex align-items-center justify-content-center py-5">
  <div class="login-card w-100" style="max-width: 440px;">

    <div class="card-header-bar text-white text-center">
      <i class="bi bi-person-badge-fill fs-1 mb-2" style="color: var(--krmu-gold);"></i>
      <div class="fw-bold fs-5">Faculty & Admin Login</div>
      <div class="mt-1"><span class="badge-soet">SOET RESOURCE PORTAL</span></div>
      <div class="opacity-75 mt-1" style="font-size:0.8rem;">KR Mangalam University</div>
    </div>

    <div class="p-4 p-md-5">

      <% if (error) { %>
        <div class="alert alert-danger d-flex align-items-start gap-2" role="alert">
          <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/auth/login" method="POST" novalidate>

        <div class="mb-3">
          <label class="form-label fw-semibold text-secondary small">University Email</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
            <input
              type="email"
              name="email"
              class="form-control"
              placeholder="yourname@krmu.edu.in"
              value="<%= email %>"
              required
              autocomplete="email"
            >
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold text-secondary small">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
            <input
              type="password"
              name="password"
              id="passwordInput"
              class="form-control"
              placeholder="Enter your password"
              required
              autocomplete="current-password"
              style="border-radius: 0 !important;"
            >
            <button
              type="button"
              class="btn btn-outline-secondary"
              style="border-radius: 0 8px 8px 0; border-left: 0;"
              onclick="togglePassword()"
            >
              <i class="bi bi-eye" id="eyeIcon"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-login w-100">
          <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
        </button>

      </form>

      <hr class="my-4">

      <div class="text-center">
        <a href="/auth/landing" class="text-decoration-none text-muted small">
          <i class="bi bi-arrow-left me-1"></i>Back to Login Options
        </a>
      </div>

      <div class="text-center mt-3 text-muted" style="font-size:0.75rem;">
        <i class="bi bi-info-circle me-1"></i>
        Students must use <a href="/auth/azure" class="text-primary">Microsoft Outlook login</a>
      </div>
    </div>
  </div>

  <script>
    function togglePassword() {
      const input = document.getElementById('passwordInput');
      const icon = document.getElementById('eyeIcon');
      if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
      } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
      }
    }
  </script>
<script src="/js/main.js"></script>
</body>
</html>